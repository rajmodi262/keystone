# --- Database ---
# For local dev both can point to the same Docker Postgres.
# For Neon: DATABASE_URL = pooled (-pooler) URL, DIRECT_URL = direct URL.
DATABASE_URL="postgresql://keystone:keystone@localhost:5433/keystone?schema=public"
DIRECT_URL="postgresql://keystone:keystone@localhost:5433/keystone?schema=public"

# --- Auth (NextAuth) ---
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-with: openssl rand -base64 32"

# --- AI provider (OPTIONAL — app runs with the local fallback if unset) ---
OPENAI_API_KEY=""
OPENAI_BASE_URL=""
LLM_MODEL="gpt-4o-mini"
EMBED_MODEL="text-embedding-3-small"
