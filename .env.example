# --- Database (Docker Postgres + pgvector) ---
DATABASE_URL="postgresql://keystone:keystone@localhost:5433/keystone?schema=public"

# --- Auth (NextAuth) ---
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-with: openssl rand -base64 32"

# --- AI provider (OPTIONAL — app runs with the local fallback if unset) ---
OPENAI_API_KEY=""
OPENAI_BASE_URL=""
LLM_MODEL="gpt-4o-mini"
EMBED_MODEL="text-embedding-3-small"
